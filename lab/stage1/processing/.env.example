# Provider selector for step4_llm_classify.py
# Allowed values: ollama, openai, gemini, anthropic
LLM_PROVIDER=ollama

# Model overrides (optional)
OLLAMA_MODEL=qwen3:8b
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# API keys (needed for cloud providers only)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=