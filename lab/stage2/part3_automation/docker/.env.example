# =============================================
# Claude Growth Machine — Environment Variables
# =============================================
# Copy this file to .env and fill in your API keys.
# At minimum: set LLM_PROVIDER + one matching API key.

# === LLM Provider (required) ===
# Which LLM classifies posts in step4. Pick ONE:
#   openai    — recommended for Docker ($0.10/3K posts, gpt-4o-mini)
#   anthropic — highest quality ($0.50/3K posts, Claude Sonnet)
#   gemini    — free tier available (Gemini Flash)
#   ollama    — free but needs --network host in Docker (local model)
LLM_PROVIDER=openai

# === LLM API Keys ===
# Set the key for your chosen provider above.

# OpenAI (recommended for Docker — cheap, fast, no host network needed)
# Cost: ~$0.10 per 3K posts with gpt-4o-mini
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Anthropic Claude (highest classification accuracy)
# Cost: ~$0.50 per 3K posts with Claude Sonnet
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini (free tier: 15 req/min)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (free tier: 14,400 req/day, very fast)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Ollama (local, free — no API key needed)
# Requires: ollama installed on host + `ollama pull qwen3:8b`
# Docker: must use --network host or set OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_HOST=http://localhost:11434

# === Scraper API Keys ===

# YouTube Data API v3 (free: 10,000 quota units/day)
# Setup: https://console.cloud.google.com → APIs & Services → YouTube Data API v3 → Credentials
YOUTUBE_API_KEY=

# Twitter/X Bearer Token (free tier: 1,500 reads/month)
# Setup: https://developer.x.com/en/portal/dashboard → Create app → Bearer Token
TWITTER_BEARER_TOKEN=

# === Alerting (optional) ===

# Slack webhook — sends anomaly alerts to a channel
# Setup: https://api.slack.com/apps → Create App → Incoming Webhooks → Add to channel
# Leave empty to disable Slack alerts (console + file logging still works)
SLACK_WEBHOOK_URL=
